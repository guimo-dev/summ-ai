# Summ-AI - Configuration
# Copy this to .env and set the three required paths below.
# All other settings have sensible defaults.

# =============================================================================
# REQUIRED: Set these to match where you built whisper.cpp and llama.cpp
# =============================================================================

# Path to the whisper-cli binary (from whisper.cpp)
# Example: /home/youruser/ai-tools/whisper.cpp/build/bin/whisper-cli
SUMMAI_WHISPER_CLI_PATH=

# Path to the Whisper GGML model file
# Example: /home/youruser/ai-tools/whisper.cpp/models/ggml-large-v3.bin
SUMMAI_WHISPER_MODEL_PATH=

# Path to the llama-server binary (from llama.cpp)
# Example: /home/youruser/ai-tools/llama.cpp/build/bin/llama-server
SUMMAI_LLAMA_SERVER_PATH=

# =============================================================================
# OPTIONAL: Everything below has sensible defaults
# =============================================================================

# --- Whisper Transcription ---
# Number of CPU threads for whisper.cpp
# SUMMAI_WHISPER_N_THREADS=4

# Language: leave empty for auto-detection, or set to 'es', 'en', etc.
# SUMMAI_WHISPER_LANGUAGE=

# Whisper beam search size
# SUMMAI_WHISPER_BEAM_SIZE=5

# Whisper initial prompt for domain vocabulary guidance (empty = general purpose)
# Set this if your meetings use specific jargon, e.g.:
# SUMMAI_WHISPER_INITIAL_PROMPT=This is a meeting about Kubernetes, Terraform, and AWS.
# SUMMAI_WHISPER_INITIAL_PROMPT=

# --- LLM Summarization ---
# HuggingFace model repo:quant (auto-downloads on first run)
# SUMMAI_LLM_HF_REPO=unsloth/Qwen3.5-9B-GGUF:Q4_K_M

# GPU layers (-1 = offload all to GPU)
# SUMMAI_LLM_N_GPU_LAYERS=-1

# Context window size
# SUMMAI_LLM_N_CTX=16384

# Server bind address and port
# SUMMAI_LLM_HOST=127.0.0.1
# SUMMAI_LLM_PORT=8079

# --- Audio ---
# Sample rate (16kHz is optimal for Whisper)
# SUMMAI_AUDIO_SAMPLE_RATE=16000

# Chunk duration in seconds (30s is a good balance)
# SUMMAI_AUDIO_CHUNK_DURATION=30

# RMS silence threshold - monitor sources have low levels (~0.002 RMS for normal audio)
# Increase if too much silence is transcribed, decrease if real audio is being filtered
# SUMMAI_SILENCE_THRESHOLD=0.001

# --- Output ---
# SUMMAI_OUTPUT_DIR=./meeting_notes
# SUMMAI_SAVE_TRANSCRIPT=true
# SUMMAI_SAVE_AUDIO=false

# --- Summarization frequency ---
# Generate intermediate summary every N chunks (prevents context loss in long meetings)
# SUMMAI_SUMMARIZE_EVERY_N_CHUNKS=10

# --- Speaker Diarization ---
# LLM-based speaker identification (adds "Speaker 1:", "Maria:", etc. to transcript)
# Uses the already-running llama-server — no extra dependencies or models.
# Disable with false or --no-diarize CLI flag if you prefer faster processing.
# SUMMAI_DIARIZE=true

# --- LLM System Prompt ---
# Override the default system prompt to customize how the LLM generates meeting notes.
# The default prompt produces structured Markdown with sections for topics, decisions,
# action items, technical references, and open questions.
# Uncomment and edit the line below to use your own prompt (use \n for newlines):
# SUMMAI_SYSTEM_PROMPT=You are a meeting note-taker. Produce structured notes in Markdown.

# Example: bilingual Spanish/English prompt for teams that mix both languages
# SUMMAI_SYSTEM_PROMPT=Eres un asistente de notas de reuniones preciso y bilingue (espanol/ingles).\nTu tarea es producir notas estructuradas en Markdown a partir de una transcripcion.\nLa reunion puede ser en espanol, ingles, o una mezcla de ambos.\n\nREGLAS:\n1. Preserva TODOS los terminos tecnicos y nombres propios exactamente como fueron dichos.\n2. Escribe las notas en el idioma dominante de la reunion. Si es mixta, usa espanol pero conserva terminos tecnicos en su idioma original.\n3. Nunca inventes informacion que no este en la transcripcion.\n4. Si algo no esta claro, marcalo como [unclear/no claro].\n5. Atribuye comentarios a los participantes cuando sea posible identificarlos.\n\nFORMATO (Markdown):\n# Notas de Reunion - [Fecha/Tema]\n## Temas Discutidos\n## Discusion Detallada\n## Decisiones Tomadas\n## Acciones Pendientes\n- [ ] Accion con responsable\n## Referencias Tecnicas\n## Preguntas Abiertas
